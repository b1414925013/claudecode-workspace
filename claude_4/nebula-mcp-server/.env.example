# NebulaGraph MCP 服务器配置示例
# 复制此文件为 nebula.env（或 .env）并填入实际值

# ===========================================
# 跳板机配置（可选）
# ===========================================
# 跳板机 IP 或主机名
BASTION_HOST=
# 跳板机 SSH 端口
BASTION_PORT=22
# 跳板机用户名
BASTION_USERNAME=
# 跳板机密码（与密钥二选一）
BASTION_PASSWORD=
# 跳板机 SSH 密钥路径（与密码二选一）
# BASTION_KEY_PATH=~/.ssh/id_rsa

# ===========================================
# 目标服务器配置（必填）
# ===========================================
# 目标服务器 IP 或主机名
TARGET_HOST=
# 目标服务器 SSH 端口
TARGET_PORT=22
# 目标服务器用户名（paas）
TARGET_USERNAME=
# 目标服务器密码（与密钥二选一）
TARGET_PASSWORD=
# 目标服务器 SSH 密钥路径（与密码二选一）
# TARGET_KEY_PATH=~/.ssh/id_rsa

# ===========================================
# NebulaGraph 配置（必填）
# ===========================================
# NebulaGraph space 名称
NEBULA_SPACE=
# NebulaGraph 连接密码
NEBULA_PASSWORD=
# NebulaGraph 主机地址（docker 内部地址）
NEBULA_HOSTS=

# ===========================================
# Docker 配置
# ===========================================
# Nebula 容器名称
DOCKER_CONTAINER=nebula